APP_NAME=Student Resume Portrait System
API_PREFIX=/api
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DATABASE_URL=sqlite:///./student_portrait.db
REDIS_URL=redis://localhost:6379/0
STORAGE_ROOT=./storage
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
EMBEDDING_PROVIDER=huggingface
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_PATH=/Users/zgsq/models/Qwen3-Embedding-0.6B
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_QUERY_INSTRUCTION=任务：根据学生简历搜索需求，检索最相关的学生简历片段，重点关注教育背景、项目经历、科研成果、实习经历、实操技能和发展方向。
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=8
CHROMA_PERSIST_DIRECTORY=./storage/chroma
SEMANTIC_SEARCH_TOP_K=5
HYBRID_SEARCH_ENABLED=true
BM25_TOP_K=20
DENSE_TOP_K_MULTIPLIER=3
RRF_K=60
RRF_DENSE_WEIGHT=1.0
RRF_KEYWORD_WEIGHT=1.0
RERANK_ENABLED=true
RERANK_PROVIDER=qwen3_local
RERANK_MODEL_PATH=/Users/zgsq/models/Qwen3-Reranker-0.6B
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=4
RERANK_MAX_LENGTH=8192
RERANK_CANDIDATE_MULTIPLIER=3
RERANK_MAX_CANDIDATES=8
RERANK_INSTRUCTION=Given a student resume search query, judge whether the resume chunk is relevant to the query.
